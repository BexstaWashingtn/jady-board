{
  "name": "jady-board",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/src/server.js",
    "start:server": "node server/src/server.js",
    "db:migrate": "node server/src/db/migrate.js",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:coverage:check": "node --test --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=80 --test-coverage-functions=80",
    "typecheck": "tsc --project jsconfig.json"
  },
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/pg": "^8.15.5",
    "jsdom": "^26.1.0",
    "typescript": "^7.0.2"
  }
}
